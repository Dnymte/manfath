*.p12
*.p8
*.pfx
*.pem
*.key
*.crt
*.cer
*.cert
*.provisionprofile
*.mobileprovision

# Secrets / config that might land in cwd
.env
.env.*
!.env.example
*.secret
secrets/
notarytool-*.json
ExportOptions.private.plist

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
*~
.fleet/
.cursor/

# Logs
*.log

# Stray script outputs
/tmp/
